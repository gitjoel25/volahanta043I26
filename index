/* Reset de base */
*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    text-decoration: none;
    border: none;
    outline: none;
    scroll-behavior: smooth;
    font-family: system-ui, -apple-system, sans-serif;
}

:root{
    --bg-color:#081b29;
    --snd-bg-color:#0c1d3c9c;
    --text-color:#fff;
    --main-color:rgb(33, 124, 139);
    --vt-color:#f65e0c;
}

html{
    font-size: 62.5%; /* 1rem = 10px */
}

body{
    background: var(--bg-color);
    color: var(--text-color);
}

section{
    min-height: 100vh;
    padding: 10rem 9% 2rem;
}

/* --- HEADER & NAVBAR --- */
.header{
    position: fixed;
    width: 100%;
    top: 0;
    left: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 5%;
    background: var(--main-color);
    backdrop-filter: blur(10px);
}

.logo{
    font-size: 2.5rem;
    color: var(--bg-color);
    font-weight: 700;
        animation: floatImage 4s ease-in-out infinite;
    transition: 0.4s ease;
    
}

#menu-icon {
    font-size: 3.6rem;
    color: var(--bg-color);
    cursor: pointer;
    display: none; /* Caché sur PC */
}

.navbar a{
    font-size: 1.8rem;
    color: var(--bg-color);
    margin-left: 4rem;
    font-weight: 700;
    transition: 0.3s ease;
}

.navbar a:hover, .navbar a.active{
    color: var(--text-color);
}

/* --- HOME SECTION --- */
.home{
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4rem;
}

.home-img img{
    width: 25vw;
    border-radius: 50%;
    box-shadow: 0 0 25px var(--main-color);
    animation: floatImage 4s ease-in-out infinite;
    transition: 0.4s ease;
    

}

@keyframes floatImage {
    0%{ transform: translateY(0); }
    50% { transform: translateY(-2.4rem); }
    100%{transform: translateY(0);}
}

.home-content h1 { font-size: 5.6rem; font-weight: 700; line-height: 1.3; }
.home-content h3 { font-size: 3.2rem; font-weight: 700; }
span { color: orangered; }
.home-content p { font-size: 1.6rem; margin: 2rem 0; }

.btn{
    display: inline-block;
    padding: 1rem 2.8rem;
    background: var(--main-color);
    border-radius: 4rem;
    font-size: 1.6rem;
    color: var(--bg-color);
    font-weight: 600;
    transition: 0.3s ease;
}

.btn:hover{
    box-shadow: 0 0 1.6rem var(--main-color);
    transform: scale(1.05);
}

/* --- ABOUT SECTION --- */
.about{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5rem;
}

.about-img img{
    width: 25vw;
    border-radius: 2rem;
    box-shadow: 0 0 25px var(--main-color);
animation: floatImage 4s ease-in-out infinite;
    transition: 0.4s ease;
}

.heading{
    font-size: 5rem;
    text-align: center;
    margin-bottom: 4rem;
    animation: floatImage 4s ease-in-out infinite;
    transition: 0.4s ease;home-
    
    
}

.about-content h3 { font-size: 2.8rem; }
.about-content p { font-size: 1.6rem; margin: 2rem 0; line-height: 1.6; }

/* --- SERVICES SECTION --- */
.services-container{
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
}

.services-box{
    flex: 1 1 30rem;
    background: var(--snd-bg-color);
    padding: 3rem 2rem;
    border-radius: 2rem;
    text-align: center;
    border: 0.2rem solid var(--vt-color);
    transition: 0.4s ease;
}

.services-box:hover{
    border-color: var(--main-color);
    transform: translateY(-1rem);
}

/* --- PROJET SECTION --- */
.projet { background: var(--snd-bg-color); }
.wrapper{
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
}

.projet-item{
    background: var(--bg-color);
    padding: 2.5rem;
    border-radius: 2rem;
    text-align: center;
    border: 0.3rem solid transparent;
    transition: 0.3s ease;
}

.projet-item img { width: 100%; border-radius: 1.5rem; margin-bottom: 1rem; }
.projet-item:hover { border-color: var(--main-color); }

/* --- CONTACT SECTION --- */
.contact form{
    max-width: 70rem;
    margin: 0 auto;
    text-align: center;
}

.contact form .input-box{
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
}

.contact form .input-box input, .contact form textarea{
    width: 100%;
    padding: 1.5rem;
    font-size: 1.6rem;
    color: var(--text-color);
    background: var(--snd-bg-color);
    border-radius: 0.8rem;
    margin: 0.8rem 0;
}

.contact form .input-box input { width: 49%; }

/* --- FOOTER --- */
footer{
    padding: 2rem 9%;
    background: var(--snd-bg-color);
    text-align: center;
}

/* --- RESPONSIVE (MOBILE) --- */

@media (max-width: 991px) {
    #menu-icon {
        display: block; /* Affiche le bouton menu */
    }

    .navbar {
        position: absolute;
        top: 100%;
        left: -100%; /* Cache le menu par défaut */
        width: 100%;
        padding: 1rem 3%;
        background: var(--main-color);
        transition: 0.4s ease;
    }

    .navbar.active {
        left: 0; /* Affiche le menu quand cliqué */
    }

    .navbar a {
        display: block;
        font-size: 2rem;
        margin: 3rem 0;
        color: var(--bg-color);
    }

    .home { flex-direction: column; }
    .home-content h1 { font-size: 4.5rem; }
    .home-img img { width: 70vw; margin-top: 4rem; }

    .about { flex-direction: column-reverse; }
    .about-img img { width: 70vw; }

    .wrapper { grid-template-columns: 1fr; } /* Projets sur une seule colonne */
    .contact form .input-box input { width: 100%; }
}

@media (max-width: 617px) {
    html { font-size: 50%; } /* Réduit la taille globale sur très petits écrans */
}

